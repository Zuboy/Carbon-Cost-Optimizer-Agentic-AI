# Carbon API credentials (store actual values in Secrets Manager — these are local-only overrides)
WATTTIME_USERNAME=your_username
WATTTIME_PASSWORD=your_password
ELECTRICITY_MAPS_API_KEY=your_api_key

# AWS deployment target
CDK_DEFAULT_REGION=us-east-1
CDK_DEFAULT_ACCOUNT=123456789012

# Set after `make deploy` — paste the MCPServerURL output here
MCP_SERVER_URL=https://your-api-gateway-id.execute-api.us-east-1.amazonaws.com/

# Override candidate regions locally (comma-separated; prod reads from SSM)
CANDIDATE_REGIONS=us-west-2,eu-north-1,ca-central-1

# Override instance power table locally (JSON; prod reads from SSM)
# INSTANCE_POWER_TABLE={"ml.g5.2xlarge":0.30,"ml.p4d.24xlarge":6.50}
